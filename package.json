  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.7",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.10",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2"
