# Server
PORT=3000
APP_URL=https://your-deployed-app.railway.app

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Mural Pay API (from your Mural sandbox dashboard)
MURAL_API_KEY=your_api_key_here
MURAL_TRANSFER_API_KEY=your_transfer_api_key_here
MURAL_API_BASE_URL=https://api-staging.muralpay.com

# Optional: simple bearer token for your API endpoints (leave blank to disable)
API_SECRET=your_secret_here

# Merchant COP bank details (fake values for sandbox)
# Get bank IDs from GET /api/counterparties/payment-methods/supported-banks
MERCHANT_FIRST_NAME=Juan
MERCHANT_LAST_NAME=Garcia
MERCHANT_EMAIL=merchant@example.com
MERCHANT_BANK_ID=bank_cop_bancolombia
MERCHANT_BANK_ACCOUNT_NUMBER=1234567890
MERCHANT_ACCOUNT_TYPE=CHECKING
MERCHANT_DOCUMENT_TYPE=NATIONAL_ID
MERCHANT_DOCUMENT_NUMBER=1234567890
MERCHANT_PHONE_NUMBER=+573001234567
MERCHANT_ADDRESS=Calle 123
MERCHANT_CITY=Bogota
MERCHANT_STATE=DC
MERCHANT_COUNTRY=CO
MERCHANT_ZIP=110111
